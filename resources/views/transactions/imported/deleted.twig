{% extends './layout/default' %}

{% block content %}
    <div class="row">
        <div class="col-lg-12 col-md-12 col-sm-12">
            <div class="box">
                <div class="box-header with-border">
                    <h3 class="box-title">{{ subTitle }}</h3>
                </div>
                <div class="box-body no-padding">
                    {% if journals|length == 0 %}
                        <div class="p-2">
                            <p class="text-muted">{{ 'deleted_imported_transactions_empty'|_ }}</p>
                        </div>
                    {% else %}
                        <table class="table table-hover">
                            <thead>
                            <tr>
                                <th>{{ 'date'|_ }}</th>
                                <th>{{ 'deleted_at'|_ }}</th>
                                <th>{{ 'type'|_ }}</th>
                                <th>{{ 'description'|_ }}</th>
                                <th>{{ 'external_id'|_ }}</th>
                                <th class="text-right">{{ 'actions'|_ }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for journal in journals %}
                                {% set externalMeta = null %}
                                {% for meta in journal.transactionJournalMeta %}
                                    {% if meta.name == 'external_id' and externalMeta is null %}
                                        {% set externalMeta = meta %}
                                    {% endif %}
                                {% endfor %}
                                <tr>
                                    <td>{{ journal.date.format('Y-m-d H:i') }}</td>
                                    <td>{{ journal.deleted_at.format('Y-m-d H:i') }}</td>
                                    <td>{{ journal.transactionType.type|capitalize }}</td>
                                    <td>{{ journal.description }}</td>
                                    <td>
                                        {% if externalMeta %}
                                            <code>{{ externalMeta.data|default('') }}</code>
                                        {% else %}
                                            <span class="text-muted">-</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-right">
                                        <form method="POST" action="{{ route('transactions.imported.restore', [journal.id]) }}" style="display:inline-block;">
                                            <input name="_token" type="hidden" value="{{ csrf_token() }}">
                                            <button type="submit" class="btn btn-xs btn-success">
                                                <span class="fa fa-undo"></span> {{ 'restore'|_ }}
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    {% endif %}
                </div>
                {% if journals|length > 0 %}
                    <div class="box-footer clearfix">
                        {{ journals.links()|raw }}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
