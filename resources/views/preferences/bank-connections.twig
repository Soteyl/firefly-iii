{% extends './layout/default' %}

{% block breadcrumbs %}
    {{ Breadcrumbs.render(Route.getCurrentRoute.getName) }}
{% endblock %}

{% block content %}
    <div class="row">
        <div class="col-lg-5 col-md-5 col-sm-12 col-xs-12">
            <div class="box box-primary">
                <div class="box-header with-border">
                    <h3 class="box-title">{{ 'connect_monobank'|_ }}</h3>
                </div>
                <form method="POST" action="{{ route('preferences.bank-connections.store') }}">
                    <input name="_token" type="hidden" value="{{ csrf_token() }}">
                    <div class="box-body">
                        <p class="text-info">{{ 'connect_monobank_help'|_ }}</p>
                        <div class="form-group">
                            <label for="access_token">{{ 'monobank_token'|_ }}</label>
                            <input type="password" class="form-control" id="access_token" name="access_token"
                                   value="{{ old('access_token') }}" autocomplete="off">
                        </div>
                    </div>
                    <div class="box-footer">
                        <button type="submit" class="btn btn-primary">{{ 'save_and_refresh_accounts'|_ }}</button>
                    </div>
                </form>
            </div>

            <div class="box box-success">
                <div class="box-header with-border">
                    <h3 class="box-title">{{ 'connect_revolut'|_ }}</h3>
                </div>
                <div class="box-body">
                    <p class="text-info">{{ 'connect_revolut_help'|_ }}</p>
                    <p class="text-muted">{{ 'connect_revolut_enable_banking_help'|_ }}</p>

                    <div class="panel panel-default">
                        <div class="panel-heading"><strong>{{ 'revolut_enable_banking_step_upload'|_ }}</strong></div>
                        <div class="panel-body">
                            <form method="POST" action="{{ route('preferences.bank-connections.revolut.enable-banking.upload-key') }}" enctype="multipart/form-data">
                                <input name="_token" type="hidden" value="{{ csrf_token() }}">
                                <div class="form-group">
                                    <label for="revolut_eb_private_key_file">{{ 'revolut_enable_banking_private_key_file'|_ }}</label>
                                    <input type="file" class="form-control" id="revolut_eb_private_key_file" name="revolut_eb_private_key_file" accept=".pem">
                                </div>
                                <button type="submit" class="btn btn-default">{{ 'revolut_enable_banking_upload_key'|_ }}</button>
                            </form>
                        </div>
                    </div>

                    <div class="panel panel-default">
                        <div class="panel-heading"><strong>{{ 'revolut_enable_banking_uploaded_keys'|_ }}</strong></div>
                        <div class="panel-body">
                            {% if revolutEnableBankingApplications|length == 0 %}
                                <p class="text-muted">{{ 'revolut_enable_banking_no_uploaded_keys'|_ }}</p>
                            {% else %}
                                <ul class="list-unstyled" style="margin-bottom:0;">
                                    {% for app in revolutEnableBankingApplications %}
                                        <li style="margin-bottom:6px;">
                                            <strong>{{ app.name }}</strong>
                                            <small class="text-muted">({{ app.application_id }}, {{ app.environment }}, {{ app.uploaded_at }})</small>
                                            {% if app.status != 'ok' and app.error %}
                                                <br><small class="text-danger">{{ app.error }}</small>
                                            {% endif %}
                                        </li>
                                    {% endfor %}
                                </ul>
                            {% endif %}
                        </div>
                    </div>

                    <div class="panel panel-default">
                        <div class="panel-heading"><strong>{{ 'revolut_enable_banking_step_1'|_ }}</strong></div>
                        <div class="panel-body">
                            <form method="POST" action="{{ route('preferences.bank-connections.revolut.enable-banking.start') }}">
                                <input name="_token" type="hidden" value="{{ csrf_token() }}">
                                <div class="form-group">
                                    <label for="revolut_eb_application_id">{{ 'revolut_enable_banking_app_id'|_ }}</label>
                                    <select class="form-control" id="revolut_eb_application_id" name="revolut_eb_application_id">
                                        <option value="">{{ 'revolut_enable_banking_select_app'|_ }}</option>
                                        {% for app in revolutEnableBankingApplications %}
                                            {% if app.status == 'ok' %}
                                                <option value="{{ app.application_id }}" {% if old('revolut_eb_application_id') == app.application_id %}selected{% endif %}>{{ app.label }}</option>
                                            {% endif %}
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label for="revolut_eb_country">{{ 'revolut_enable_banking_country'|_ }}</label>
                                    <input type="text" class="form-control" id="revolut_eb_country" name="revolut_eb_country"
                                           value="{{ old('revolut_eb_country', 'IE') }}" autocomplete="off">
                                </div>
                                <button type="submit" class="btn btn-default" formtarget="_blank">{{ 'revolut_enable_banking_start_auth'|_ }}</button>
                            </form>
                            <p class="text-muted" style="margin-top:8px;margin-bottom:0;">{{ 'revolut_enable_banking_callback_info'|_ }}</p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
        <div class="col-lg-7 col-md-7 col-sm-12 col-xs-12">
            <div class="box box-default">
                <div class="box-header with-border">
                    <h3 class="box-title">{{ 'bank_connections'|_ }}</h3>
                </div>
                <div class="box-body">
                    {% if errors.any %}
                        <div class="alert alert-danger" role="alert">
                            <ul>
                                {% for bag in errors.getBags %}
                                    {% for error in bag.all %}
                                        <li>{{ error }}</li>
                                    {% endfor %}
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}

                    <div class="panel panel-info">
                        <div class="panel-heading">
                            <strong>{{ 'bank_connection_category_rules'|_ }}</strong>
                        </div>
                        <div class="panel-body">
                            <p class="text-muted">{{ 'bank_connection_category_rules_help'|_ }}</p>
                            {% set mccRules = categoryRules.mcc|default([]) %}
                            {% set overrideRules = categoryRules.overrides|default([]) %}
                            {% set mccRows = mccRules|merge([{'mcc':'', 'category_id':'', 'enabled': true}]) %}
                            {% set overrideRows = overrideRules|merge([{'external_id':'', 'description_contains':'', 'mcc':'', 'category_id':'', 'enabled': true}]) %}
                            <form method="POST" action="{{ route('preferences.bank-connections.category-rules.update') }}">
                                <input name="_token" type="hidden" value="{{ csrf_token() }}">

                                <h5>{{ 'bank_connection_mcc_rules'|_ }}</h5>
                                <div class="table-responsive">
                                    <table class="table table-condensed table-striped">
                                        <thead>
                                        <tr>
                                            <th style="width: 280px;">MCC</th>
                                            <th>{{ 'category'|_ }}</th>
                                            <th style="width: 110px;">{{ 'enabled'|_ }}</th>
                                        </tr>
                                        </thead>
                                        <tbody>
                                        {% for rule in mccRows %}
                                            <tr>
                                                <td>
                                                    <select name="mcc_rules[{{ loop.index0 }}][mcc]" class="form-control input-sm">
                                                        <option value=""></option>
                                                        {% if rule.mcc|default('') != '' and mccOptions[rule.mcc] is not defined %}
                                                            <option value="{{ rule.mcc }}" selected>{{ rule.mcc }} - Custom</option>
                                                        {% endif %}
                                                        {% for mcc, title in mccOptions %}
                                                            <option value="{{ mcc }}" {% if (rule.mcc|default('')) == mcc %}selected{% endif %}>{{ mcc }} - {{ title }}</option>
                                                        {% endfor %}
                                                    </select>
                                                </td>
                                                <td>
                                                    <select name="mcc_rules[{{ loop.index0 }}][category_id]" class="form-control input-sm">
                                                        <option value="">{{ 'no_category'|_ }}</option>
                                                        {% for category in categories %}
                                                            <option value="{{ category.id }}" {% if (rule.category_id|default(0)) == category.id %}selected{% endif %}>{{ category.name }}</option>
                                                        {% endfor %}
                                                    </select>
                                                </td>
                                                <td>
                                                    <label class="checkbox-inline" style="margin-top:0;">
                                                        <input type="checkbox" name="mcc_rules[{{ loop.index0 }}][enabled]" value="1" {% if rule.enabled is not defined or rule.enabled %}checked{% endif %}>
                                                        {{ 'enabled'|_ }}
                                                    </label>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>
                                </div>

                                <h5>{{ 'bank_connection_override_rules'|_ }}</h5>
                                <p class="text-muted">{{ 'bank_connection_override_rules_help'|_ }}</p>
                                <div class="table-responsive">
                                    <table class="table table-condensed table-striped">
                                        <thead>
                                        <tr>
                                            <th>{{ 'external_id'|_ }}</th>
                                            <th>{{ 'description'|_ }}</th>
                                            <th style="width: 280px;">MCC</th>
                                            <th>{{ 'category'|_ }}</th>
                                            <th style="width: 110px;">{{ 'enabled'|_ }}</th>
                                        </tr>
                                        </thead>
                                        <tbody>
                                        {% for rule in overrideRows %}
                                            <tr>
                                                <td>
                                                    <input type="text" name="override_rules[{{ loop.index0 }}][external_id]" class="form-control input-sm" value="{{ rule.external_id|default('') }}" placeholder="exact external_id">
                                                </td>
                                                <td>
                                                    <input type="text" name="override_rules[{{ loop.index0 }}][description_contains]" class="form-control input-sm" value="{{ rule.description_contains|default('') }}" placeholder="contains text">
                                                </td>
                                                <td>
                                                    <select name="override_rules[{{ loop.index0 }}][mcc]" class="form-control input-sm">
                                                        <option value=""></option>
                                                        {% if rule.mcc|default('') != '' and mccOptions[rule.mcc] is not defined %}
                                                            <option value="{{ rule.mcc }}" selected>{{ rule.mcc }} - Custom</option>
                                                        {% endif %}
                                                        {% for mcc, title in mccOptions %}
                                                            <option value="{{ mcc }}" {% if (rule.mcc|default('')) == mcc %}selected{% endif %}>{{ mcc }} - {{ title }}</option>
                                                        {% endfor %}
                                                    </select>
                                                </td>
                                                <td>
                                                    <select name="override_rules[{{ loop.index0 }}][category_id]" class="form-control input-sm">
                                                        <option value="">{{ 'no_category'|_ }}</option>
                                                        {% for category in categories %}
                                                            <option value="{{ category.id }}" {% if (rule.category_id|default(0)) == category.id %}selected{% endif %}>{{ category.name }}</option>
                                                        {% endfor %}
                                                    </select>
                                                </td>
                                                <td>
                                                    <label class="checkbox-inline" style="margin-top:0;">
                                                        <input type="checkbox" name="override_rules[{{ loop.index0 }}][enabled]" value="1" {% if rule.enabled is not defined or rule.enabled %}checked{% endif %}>
                                                        {{ 'enabled'|_ }}
                                                    </label>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>
                                </div>

                                <button type="submit" class="btn btn-default">{{ 'save_category_rules'|_ }}</button>
                            </form>
                        </div>
                    </div>

                    {% if connections|length == 0 %}
                        <p class="text-muted">{{ 'no_bank_connections_yet'|_ }}</p>
                    {% endif %}

                    {% for connection in connections %}
                        <div class="panel panel-default">
                            <div class="panel-heading">
                                <strong>{{ connection.provider|capitalize }}</strong>
                                <span class="label label-default">{{ connection.status }}</span>
                            </div>
                            <div class="panel-body">
                                <p>
                                    {% if connection.provider == 'monobank' %}
                                        <strong>{{ 'webhook_enabled'|_ }}:</strong>
                                        {{ connection.webhook_enabled ? 'yes'|_ : 'no'|_ }}
                                        <br>
                                    {% endif %}
                                    <strong>{{ 'last_successful_sync'|_ }}:</strong>
                                    {% if connection.last_successful_sync_at %}
                                        {{ connection.last_successful_sync_at.format('Y-m-d H:i:s') }}
                                    {% else %}
                                        {{ 'never'|_ }}
                                    {% endif %}
                                </p>

                                {% if connection.last_error_message %}
                                    <div class="alert alert-warning">
                                        {{ connection.last_error_message }}
                                    </div>
                                {% endif %}

                                <div class="btn-group">
                                    {% if connection.provider == 'revolut' %}
                                        <form method="POST" action="{{ route('preferences.bank-connections.revolut.validate-token', connection.id) }}" style="display:inline;">
                                            <input name="_token" type="hidden" value="{{ csrf_token() }}">
                                            <button type="submit" class="btn btn-default">{{ 'validate_token'|_ }}</button>
                                        </form>
                                        <form method="POST" action="{{ route('preferences.bank-connections.revolut.refresh-accounts', connection.id) }}" style="display:inline;">
                                            <input name="_token" type="hidden" value="{{ csrf_token() }}">
                                            <button type="submit" class="btn btn-default">{{ 'refresh_accounts'|_ }}</button>
                                        </form>
                                        <form method="POST" action="{{ route('preferences.bank-connections.revolut.sync', connection.id) }}" style="display:inline;">
                                            <input name="_token" type="hidden" value="{{ csrf_token() }}">
                                            <button type="submit" class="btn btn-primary">{{ 'sync_now'|_ }}</button>
                                        </form>
                                    {% else %}
                                        <form method="POST" action="{{ route('preferences.bank-connections.validate-token', connection.id) }}" style="display:inline;">
                                            <input name="_token" type="hidden" value="{{ csrf_token() }}">
                                            <button type="submit" class="btn btn-default">{{ 'validate_token'|_ }}</button>
                                        </form>
                                        <form method="POST" action="{{ route('preferences.bank-connections.refresh-accounts', connection.id) }}" style="display:inline;">
                                            <input name="_token" type="hidden" value="{{ csrf_token() }}">
                                            <button type="submit" class="btn btn-default">{{ 'refresh_accounts'|_ }}</button>
                                        </form>
                                        <form method="POST" action="{{ route('preferences.bank-connections.sync', connection.id) }}" style="display:inline;">
                                            <input name="_token" type="hidden" value="{{ csrf_token() }}">
                                            <button type="submit" class="btn btn-primary">{{ 'sync_now'|_ }}</button>
                                        </form>
                                    {% endif %}
                                </div>

                                <hr>
                                <h4>{{ connection.provider == 'revolut' ? 'revolut_accounts'|_ : 'monobank_accounts'|_ }}</h4>
                                {% if connection.bankConnectionAccounts|length == 0 %}
                                    <p class="text-muted">{{ connection.provider == 'revolut' ? 'no_revolut_accounts'|_ : 'no_monobank_accounts'|_ }}</p>
                                {% else %}
                                    <div class="table-responsive">
                                        <table class="table table-striped">
                                            <thead>
                                            <tr>
                                                <th>{{ 'account'|_ }}</th>
                                                <th>{{ 'currency'|_ }}</th>
                                                <th>{{ 'mapped_firefly_account'|_ }}</th>
                                                <th>{{ 'first_import_from_date'|_ }}</th>
                                                <th>{{ 'status'|_ }}</th>
                                                <th>{{ 'actions'|_ }}</th>
                                            </tr>
                                            </thead>
                                            <tbody>
                                            {% for account in connection.bankConnectionAccounts %}
                                                <tr>
                                                    <td>
                                                        {% if connection.provider == 'revolut' %}
                                                            <strong>{{ account.revolut_account_name ?: 'n/a' }}</strong>
                                                            {% if account.revolut_account_id %}
                                                                <br><code>{{ account.revolut_account_id }}</code>
                                                            {% endif %}
                                                            {% if account.revolut_wallet_id %}
                                                                <br><small>{{ 'revolut_wallet_id_label'|_ }}: {{ account.revolut_wallet_id }}</small>
                                                            {% endif %}
                                                        {% else %}
                                                            <code>{{ account.mono_account_id }}</code>
                                                            {% if account.mono_masked_pan %}
                                                                <br><small>{{ account.mono_masked_pan }}</small>
                                                            {% endif %}
                                                            {% if account.mono_iban %}
                                                                <br><small>{{ account.mono_iban }}</small>
                                                            {% endif %}
                                                        {% endif %}
                                                    </td>
                                                    <td>
                                                        {% if connection.provider == 'revolut' %}
                                                            {{ account.revolut_currency_code ?: 'n/a' }}
                                                        {% else %}
                                                            {{ account.mono_currency_code ?: 'n/a' }}
                                                        {% endif %}
                                                    </td>
                                                    <td>
                                                        <form method="POST" action="{{ route('preferences.bank-connections.accounts.update', [connection.id, account.id]) }}">
                                                            <input name="_token" type="hidden" value="{{ csrf_token() }}">
                                                            <select name="firefly_account_id" class="form-control input-sm">
                                                                <option value="">{{ 'not_mapped_yet'|_ }}</option>
                                                                {% for fireflyAccount in assetAccounts %}
                                                                    <option value="{{ fireflyAccount.id }}" {% if account.firefly_account_id == fireflyAccount.id %}selected{% endif %}>{{ fireflyAccount.name }}</option>
                                                                {% endfor %}
                                                            </select>
                                                    </td>
                                                    <td>
                                                            {% set firstImportDate = account.sync_from_ts ? account.sync_from_ts|date('Y-m-d') : '' %}
                                                            <input
                                                                    type="date"
                                                                    name="first_import_from_date"
                                                                    class="form-control input-sm"
                                                                    value="{{ firstImportDate }}"
                                                                    {% if account.last_synced_statement_ts %}disabled{% endif %}
                                                            >
                                                            <small class="text-muted">
                                                                {{ account.last_synced_statement_ts ? 'first_import_date_locked'|_ : 'first_import_date_help'|_ }}
                                                            </small>
                                                    </td>
                                                    <td>
                                                            <label class="checkbox-inline" style="margin-top:0;">
                                                                <input type="checkbox" name="enabled" value="1" {% if account.enabled %}checked{% endif %}>
                                                                {{ account.enabled ? 'enabled'|_ : 'disabled'|_ }}
                                                            </label>
                                                    </td>
                                                    <td>
                                                            <button type="submit" class="btn btn-xs btn-default">{{ 'save_mapping'|_ }}</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                            </tbody>
                                        </table>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
