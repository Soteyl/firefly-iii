{% extends './layout/default' %}

{% block breadcrumbs %}
    {{ Breadcrumbs.render(Route.getCurrentRoute.getName) }}
{% endblock %}

{% block content %}
    <div class="row">
        <div class="col-lg-8 col-lg-offset-2 col-md-10 col-md-offset-1 col-sm-12 col-xs-12">
            {% if errors.any %}
                <div class="alert alert-danger" role="alert">
                    <ul>
                        {% for bag in errors.getBags %}
                            {% for error in bag.all %}
                                <li>{{ error }}</li>
                            {% endfor %}
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

            <div class="box box-warning">
                <div class="box-header with-border">
                    <h3 class="box-title">{{ 'telegram_assistant_settings'|_ }}</h3>
                </div>
                <div class="box-body">
                    <p class="text-muted">{{ 'telegram_assistant_settings_help'|_ }}</p>
                    <form method="POST" action="{{ route('profile.telegram-assistant.update') }}">
                        <input name="_token" type="hidden" value="{{ csrf_token() }}">

                        <div class="form-group">
                            <label for="telegram_user_id">
                                {{ 'telegram_user_id'|_ }}
                                <span class="text-muted" title="{{ 'telegram_user_id_tooltip'|_ }}">(?)</span>
                            </label>
                            <input
                                type="text"
                                class="form-control"
                                id="telegram_user_id"
                                name="telegram_user_id"
                                value="{{ old('telegram_user_id', telegramAssistant.telegram_user_id|default('')) }}"
                                placeholder="123456789"
                            >
                        </div>

                        <div class="form-group">
                            <label for="openai_api_token">{{ 'telegram_assistant_openai_api_token'|_ }}</label>
                            <input
                                type="password"
                                class="form-control"
                                id="openai_api_token"
                                name="openai_api_token"
                                value=""
                                autocomplete="off"
                                placeholder="sk-..."
                            >
                            {% if telegramAssistant.openai_api_token_masked|default('') != '' %}
                                <small class="text-muted">{{ telegramAssistant.openai_api_token_masked }}</small>
                            {% else %}
                                <small class="text-muted">{{ 'telegram_assistant_openai_api_token_help'|_ }}</small>
                            {% endif %}
                        </div>

                        <div class="form-group">
                            <label for="openai_model">{{ 'telegram_assistant_model'|_ }}</label>
                            <select class="form-control" id="openai_model" name="openai_model">
                                {% for modelId, modelLabel in openAiModelOptions %}
                                    <option value="{{ modelId }}" {% if old('openai_model', telegramAssistant.openai_model|default('')) == modelId %}selected{% endif %}>
                                        {{ modelLabel }} ({{ modelId }})
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        <hr>
                        <h4>{{ 'telegram_assistant_oauth'|_ }}</h4>
                        <p class="text-muted">{{ 'telegram_assistant_oauth_help'|_ }}</p>
                        <div class="form-group">
                            <label for="openai_oauth_result_url">{{ 'telegram_assistant_oauth_result_url'|_ }}</label>
                            <input
                                type="url"
                                class="form-control"
                                id="openai_oauth_result_url"
                                name="openai_oauth_result_url"
                                value="{{ old('openai_oauth_result_url') }}"
                                placeholder="http://localhost:1455/auth/callback?code=...&state=..."
                            >
                            <small class="text-muted">
                                {{ 'telegram_assistant_oauth_result_url_help'|_ }}<br>
                                {{ 'telegram_assistant_oauth_callback_url'|_ }}: <code>{{ telegramAssistantOauthCallbackUrl }}</code>
                            </small>
                        </div>

                        <button type="submit" class="btn btn-default">{{ 'telegram_assistant_save_settings'|_ }}</button>
                        <a class="btn btn-primary" href="{{ route('profile.telegram-assistant.openai.oauth.start') }}" target="_blank">{{ 'telegram_assistant_connect_oauth'|_ }}</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
